---
import ChartExample from '../../components/ChartExample';
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Line chart example';
---

<BaseLayout title={title}>
  <section class="example-header">
    <p class="eyebrow">Examples</p>
    <h1>{title}</h1>
    <p>
      A responsive area and line chart composed from Chartly primitives.
    </p>
  </section>

  <section class="example-shell">
    <ChartExample client:load />
  </section>

  <style>
    .example-header {
      margin-bottom: 2rem;
    }

    .eyebrow {
      margin: 0 0 0.75rem;
      color: #5eead4;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    h1 {
      margin: 0 0 1rem;
      color: #f8fafc;
      font-size: clamp(2.25rem, 6vw, 4rem);
      line-height: 1;
    }

    .example-header p {
      max-width: 680px;
      margin: 0;
    }

    .example-shell {
      width: 100%;
      border: 1px solid #2b303a;
      border-radius: 8px;
      background: #f8fafc;
      padding: 1.5rem;
    }
  </style>
</BaseLayout>
