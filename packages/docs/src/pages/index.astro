---
import HomeChart from '../components/HomeChart';
import BaseLayout from '../layouts/BaseLayout.astro';
import { Code } from 'astro:components';

const title = 'Chartly documentation';

const homeChartSource = `import React from 'react';
import {
  Area,
  CartesianGrid,
  ChartContainer,
  Line,
  LinearGradient,
  XAxis,
  YAxis,
} from 'chartly';

interface Row {
  label: string;
  value: number;
}

const data: Row[] = [
  { label: 'Jan', value: 320 },
  { label: 'Feb', value: 460 },
  { label: 'Mar', value: 380 },
  { label: 'Apr', value: 620 },
  { label: 'May', value: 540 },
  { label: 'Jun', value: 880 },
  { label: 'Jul', value: 760 },
  { label: 'Aug', value: 940 },
];

export default function HomeChart(): React.JSX.Element {
  return (
    <div style={{ width: '100%', height: 320 }}>
      <ChartContainer
        data={data}
        xKey="label"
        xScaleType="band"
        yKey="value"
        yScaleType="linear"
        margin={{ top: 20, right: 24, bottom: 34, left: 52 }}
      >
        <LinearGradient
          id="homeChartFill"
          from="#5eead4"
          to="#38bdf8"
          fromOpacity={0.25}
          toOpacity={0.02}
        />
        <CartesianGrid stroke="#334155" strokeOpacity={0.75} dashArray="4 6" />
        <XAxis stroke="#64748b" textFill="#cbd5e1" />
        <YAxis stroke="#64748b" textFill="#cbd5e1" />
        <Area fill="url(#homeChartFill)" curve="monotone" />
        <Line stroke="#5eead4" strokeWidth={2} curve="monotone" />
      </ChartContainer>
    </div>
  );
}`;
---

<BaseLayout title={title}>
  <section class="hero">
    <p class="eyebrow">TypeScript-first. D3-powered. React-native.</p>
    <h1>Chartly</h1>
    <p class="tagline">
      A composable charting library for building polished, typed SVG charts with
      React components.
    </p>
    <div class="actions" aria-label="Primary actions">
      <a class="install" href="/examples/line/">
        <span>Install v0.0.0</span>
        <code>npm install chartly</code>
      </a>
    </div>
    <HomeChart client:load />
    <div class="source-panel">
      <div class="source-toolbar">
        <span class="window-dots" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span>HomeChart.tsx</span>
      </div>
      <div class="source-code">
        <Code code={homeChartSource} lang="tsx" theme="github-dark" />
      </div>
    </div>
  </section>

  <section class="feature-grid" aria-label="Chartly features">
    <article>
      <h2>Composable primitives</h2>
      <p>
        Mix containers, axes, grids, gradients, shapes, legends, and tooltips
        using ordinary React composition.
      </p>
    </article>
    <article>
      <h2>Typed data access</h2>
      <p>
        Chart keys and accessors are checked by TypeScript, including linear,
        time, and band scale inputs.
      </p>
    </article>
    <article>
      <h2>Built on D3 scales</h2>
      <p>
        Chartly keeps the declarative React surface while leaning on D3 for
        reliable scales, shapes, and chart math.
      </p>
    </article>
  </section>

  <style>
    .hero {
      min-height: calc(100vh - 64px);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      margin-bottom: 4rem;
      padding: 2rem 0 3rem;
    }

    .eyebrow {
      margin: 0 0 1rem;
      color: #5eead4;
      font-size: 0.85rem;
      font-weight: 800;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      color: #67e8f9;
      font-size: clamp(4rem, 10vw, 6.75rem);
      line-height: 0.95;
      font-weight: 800;
    }

    .tagline {
      max-width: 720px;
      margin: 1.75rem auto 0;
      color: #f8fafc;
      font-size: clamp(1.15rem, 2.5vw, 1.55rem);
      line-height: 1.45;
    }

    .actions {
      margin-top: 2rem;
      display: flex;
      justify-content: center;
    }

    .install {
      min-width: min(100%, 280px);
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
      border-radius: 6px;
      background: #2f9ce5;
      color: white;
      padding: 0.85rem 1.5rem;
      font-weight: 800;
      box-shadow: 0 14px 30px rgba(47, 156, 229, 0.24);
    }

    .install code {
      color: #eff6ff;
      background: transparent;
      padding: 0;
      font-size: 0.78rem;
    }

    .source-panel {
      width: min(100%, 760px);
      margin: 1rem auto 0;
      overflow: hidden;
      border: 1px solid #2b303a;
      border-radius: 14px;
      background: #020617;
      text-align: left;
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
    }

    .source-toolbar {
      border-bottom: 1px solid #2b303a;
      background: #111318;
      color: #cbd5e1;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.8rem 1rem;
      font-size: 0.85rem;
      font-weight: 700;
    }

    .window-dots {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
    }

    .window-dots span {
      width: 0.65rem;
      height: 0.65rem;
      border-radius: 999px;
      background: #3f4652;
    }

    .source-code {
      max-height: 540px;
      overflow: auto;
      background: #020617;
    }

    .source-code :global(pre) {
      max-height: 520px;
      margin: 0;
      border: 0;
      border-radius: 0;
      background: #020617 !important;
      padding: 1.1rem 1.25rem;
    }

    .source-code :global(code) {
      background: transparent;
      padding: 0;
      border-radius: 0;
      font-size: 0.86rem;
      line-height: 1.7;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      overflow: hidden;
      border: 1px solid #2b303a;
      border-radius: 8px;
      background: #2b303a;
    }

    .feature-grid article {
      min-height: 190px;
      background: #181b22;
      padding: 1.5rem;
    }

    .feature-grid h2 {
      margin: 0 0 0.75rem;
      color: #f8fafc;
      font-size: 1.1rem;
    }

    .feature-grid p {
      margin: 0;
    }

    @media (max-width: 820px) {
      .hero {
        justify-content: flex-start;
        min-height: auto;
      }

      .feature-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
