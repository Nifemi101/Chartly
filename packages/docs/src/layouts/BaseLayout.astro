---
const { title } = Astro.props;

const navItems = [
  { href: '/', label: 'Guide' },
  { href: '/examples/line/', label: 'Examples' },
  { href: '/api/', label: 'API' },
  { href: 'https://www.npmjs.com/package/chartly', label: 'npm' },
  { href: 'https://github.com/', label: 'GitHub' },
];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #111318;
        --panel: #181b22;
        --panel-soft: #20242d;
        --border: #2b303a;
        --text: #f8fafc;
        --muted: #a8b0bd;
        --brand: #38bdf8;
        --brand-strong: #5eead4;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Inter, system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      main {
        width: min(100%, 1120px);
        margin: 0 auto;
        padding: 4.5rem 1.5rem 5rem;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      p {
        color: var(--muted);
        line-height: 1.7;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        border-bottom: 1px solid var(--border);
        background: rgba(24, 27, 34, 0.94);
        backdrop-filter: blur(12px);
      }

      .nav {
        width: min(100%, 1180px);
        min-height: 64px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        gap: 2rem;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        color: var(--brand);
        font-size: 1.1rem;
        font-weight: 700;
        white-space: nowrap;
      }

      .brand code {
        color: inherit;
        background: transparent;
        padding: 0;
        border-radius: 0;
        font-size: inherit;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 1.6rem;
        flex-wrap: wrap;
      }

      .nav-links a {
        color: #c7ccd5;
        font-size: 0.95rem;
        font-weight: 600;
      }

      .nav-links a:hover {
        color: var(--brand-strong);
      }

      section {
        margin-bottom: 2rem;
      }

      code {
        background: rgba(148, 163, 184, 0.15);
        padding: 0.25rem 0.45rem;
        border-radius: 0.35rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      }

      pre {
        overflow: auto;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: #0b0d12;
        padding: 1rem;
      }

      :global(.home-chart) {
        width: min(100%, 760px);
        height: 320px;
        margin: 2.5rem auto 0;
      }

      @media (max-width: 720px) {
        main {
          padding-top: 3rem;
        }

        .nav {
          align-items: flex-start;
          flex-direction: column;
          gap: 0.75rem;
          padding-top: 1rem;
          padding-bottom: 1rem;
        }

        .nav-links {
          gap: 1rem;
        }

        :global(.home-chart) {
          height: 260px;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label="Chartly home">
          <code>&lt;Chartly /&gt;</code>
        </a>
        <div class="nav-links">
          {navItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
