---
import BaseLayout from './BaseLayout.astro';
import { exampleCategories } from '../data/examples';

interface Props {
  title: string;
}
const { title } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<BaseLayout title={title}>
  <div class="flex flex-col gap-4 sm:mx-[-1.5rem] sm:gap-8 lg:flex-row lg:gap-10">
    <details open class="sidebar-details rounded-lg border border-border bg-panel/40 lg:sticky lg:top-24 lg:h-[calc(100vh-8rem)] lg:w-64 lg:shrink-0 lg:overflow-y-auto lg:rounded-none lg:border-0 lg:bg-transparent">
      <summary class="flex cursor-pointer select-none items-center justify-between px-4 py-3 text-sm font-semibold text-text lg:hidden">
        Browse examples
        <svg class="summary-chevron h-4 w-4 text-muted transition-transform" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 9l6 6 6-6" />
        </svg>
      </summary>
      <nav class="guide-nav px-4 pb-6 pt-2 sm:px-6 lg:pl-6 lg:pr-2 lg:pt-0" aria-label="Examples navigation">
        <a
          href="/examples/"
          class={
            currentPath === '/examples'
              ? 'mb-6 block text-xl font-semibold text-brand-strong'
              : 'mb-6 block text-xl font-semibold text-text transition-colors hover:text-brand-strong'
          }
        >
          Examples
        </a>
        {exampleCategories.map((category) => {
          const categoryActive = currentPath.startsWith(category.basePath);
          return (
            <div class="mb-6">
              <a
                href={category.firstExampleHref}
                class={
                  categoryActive
                    ? 'mb-2 block text-[0.7rem] font-semibold uppercase tracking-wider text-brand-strong'
                    : 'mb-2 block text-[0.7rem] font-semibold uppercase tracking-wider text-text transition-colors hover:text-brand-strong'
                }
              >
                {category.heading}
              </a>
              <ul class="flex flex-col gap-0.5 border-l border-border">
                {category.examples.map((link) => {
                  const linkActive = currentPath === link.href.replace(/\/$/, '');
                  return (
                    <li>
                      <a
                        class={
                          linkActive
                            ? 'block -ml-px border-l-2 border-brand-strong pl-3 py-1 text-sm font-medium text-text'
                            : 'block -ml-px border-l-2 border-transparent pl-3 py-1 text-sm text-muted transition-colors hover:border-zinc-600 hover:text-text'
                        }
                        href={link.href}
                      >
                        {link.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          );
        })}
      </nav>
    </details>

    <article class="min-w-0 flex-1 pb-16 sm:px-6">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .sidebar-details summary::-webkit-details-marker { display: none; }
  .sidebar-details summary { list-style: none; }
  .sidebar-details[open] .summary-chevron { transform: rotate(180deg); }
  @media (min-width: 1024px) {
    .sidebar-details > nav { display: block !important; }
  }
</style>
